<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Application Icon: Game Controller + EOS Lighting Fusion -->
    <DrawingImage x:Key="AppIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Background Glow / Ambient Stage Light -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush Center="0.5,0.3" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#40FF8C00" Offset="0"/>
                            <GradientStop Color="#00FF8C00" Offset="1"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="16,16" RadiusX="14" RadiusY="14"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Stage Light Beam Emitters (Top Down) -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#CCFF8C00" Offset="0"/>
                            <GradientStop Color="#1AFF8C00" Offset="0.8"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <!-- A cone of light beaming down onto the controller -->
                        <PathGeometry Figures="M 10,2 L 22,2 L 28,18 L 4,18 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Game Controller Body -->
                <GeometryDrawing Brush="#FF2D2D30">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#FFD0D0D0" Thickness="1.5" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <!-- Smoothly modeled controller chassis -->
                        <PathGeometry Figures="M 8,12 C 5,12 3,14 3,18 C 3,24 5,27 8,27 C 10,27 12,24 13,22 L 19,22 C 20,24 22,27 25,27 C 28,27 30,24 30,18 C 30,14 28,12 25,12 L 8,12 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Left D-Pad (Classic Cross) -->
                <GeometryDrawing Brush="#FF555555">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 7,16 L 9,16 L 9,14 L 11,14 L 11,16 L 13,16 L 13,18 L 11,18 L 11,20 L 9,20 L 9,18 L 7,18 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Right Buttons / Action Gems (Colored like EOS Eos/Gio Magic Sheets) -->
                <GeometryDrawing Brush="#FF00A2E8">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="24,16" RadiusX="1.2" RadiusY="1.2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#FF22B14C">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="26,18" RadiusX="1.2" RadiusY="1.2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#FFFF8C00">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="22,18" RadiusX="1.2" RadiusY="1.2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Center Connectivity/Link Element -->
                <GeometryDrawing Brush="#FFFF8C00">
                    <GeometryDrawing.Geometry>
                        <!-- Small patch indicating a network/data connection link in the center -->
                        <PathGeometry Figures="M 15,16 L 17,16 L 16,19 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>
    
    <Style TargetType="Window">
    </Style>
    <Style TargetType="Label">
        <Setter Property="Margin" Value="4" />
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style TargetType="Button">
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Background" Value="DarkGray" />
    </Style>
    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="4" />
    </Style>

</ResourceDictionary>