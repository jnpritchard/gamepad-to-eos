<Window x:Class="XboxEOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XboxEOS"
        mc:Ignorable="d"
        Title="Game Controller for EOS Interface" Height="670" Width="800"
        Closing="Window_Closing" ResizeMode="CanMinimize"
        Icon="{StaticResource AppIcon}"
        >
    <Grid RowDefinitions="auto,auto,auto,auto,auto,auto,auto,auto,auto,auto,*,auto,auto" ColumnDefinitions="auto,*">

        <Label Content="Choose your controller and start monitoring, press connect to connect EOS." Grid.Row="0" Grid.ColumnSpan="2" VerticalAlignment="Center" />
        <Image Source="/instruction.jpg" Grid.Row="1" Grid.ColumnSpan="2" Height="160" HorizontalAlignment="Center" />

        <Label Content="Controllers" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
        <ListBox x:Name="listOfDevices" Grid.Row="2" DisplayMemberPath="InstanceName" Grid.Column="1" />
        <!-- Row -->
        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="startMonitoringButton" Content="Start Monitoring" Click="StartMonitoring_Click" />
            <Button x:Name="stopMonitoringButton" Content="Stop Monitoring" Click="StopMonitoring_Click" />
            <Button x:Name="connectButton" Content="Connect" Click="Connect_Click" />
            <Button x:Name="disconnectButton" Content="Disconnect" Click="Disconnect_Click" />
        </StackPanel>
        <!-- Row -->
        <Label Content="X Axis" Grid.Row="4" Grid.Column="0" />
        <ProgressBar x:Name="xAxisIndicator" Minimum="0" Maximum="65535" Grid.Row="4" Grid.Column="1" />
        <!-- Row -->
        <Label Content="Y Axis" Grid.Row="5" Grid.Column="0" />
        <ProgressBar x:Name="yAxisIndicator" Minimum="0" Maximum="65535" Grid.Row="5" Grid.Column="1" />
        <!-- Row -->
        <Label Content="Z Axis" Grid.Row="6" Grid.Column="0"  />
        <ProgressBar x:Name="zAxisIndicator" Minimum="0" Maximum="65535" Grid.Row="6" Grid.Column="1" />
        <!-- Row -->
        <Label Content="X Rotation Axis" Grid.Row="7" Grid.Column="0"  />
        <ProgressBar x:Name="xRotationAxisIndicator" Minimum="0" Maximum="65535" Grid.Row="7" Grid.Column="1" />
        <!-- Row -->
        <Label Content="Y Rotation Axis" Grid.Row="8" Grid.Column="0"  />
        <ProgressBar x:Name="yRotationAxisIndicator" Minimum="0" Maximum="65535" Grid.Row="8" Grid.Column="1" />

        <StackPanel Orientation="Horizontal" Grid.Row="9" Grid.ColumnSpan="2" HorizontalAlignment="Stretch">
            <Label Content="Sensitivity" />
            <CheckBox Content="Coarse" IsChecked="False"  x:Name="checkboxIsCoarse" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
            <Slider x:Name="sliderSensitivity" Minimum="0" Maximum="1" Value="0.5" Width="300" ValueChanged="sliderSensitivity_ValueChanged" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
            <Label x:Name="labelSensitivity" Content="0.2" />
        </StackPanel>
        
        
        <!-- OSC Grid -->
        <Grid Grid.Row="10" Grid.ColumnSpan="2" RowDefinitions="*,*,*" ColumnDefinitions="*,*,*">
            <Button Grid.Row="0" Grid.Column="0" Content="Prev" Click="Button_Prev_Click" />
            <Button Grid.Row="0" Grid.Column="1" Content="Up" Click="Button_Up_Click" />
            <Button Grid.Row="0" Grid.Column="2" Content="Next" Click="Button_Next_Click" />

            <Button Grid.Row="1" Grid.Column="0" Content="Left" Click="Button_Left_Click" />
            <Button Grid.Row="1" Grid.Column="2" Content="Right" Click="Button_Right_Click" />

            <Button Grid.Row="2" Grid.Column="1" Content="Down" Click="Button_Down_Click" />
        </Grid>
        <!-- Row -->
        <Label Grid.Row="11" Content="Input State" Grid.Column="0" />
        <TextBlock x:Name="joystickStateTextBlock" Grid.Row="11" Grid.Column="1" Text="No data" VerticalAlignment="Center" />
        <!-- Row -->
        <Label Grid.Row="12" Content="OSC Messages" Grid.Column="0" />
        <TextBlock x:Name="oscMessageTextBlock" Grid.Row="12" Grid.Column="1" Text="No Messages" VerticalAlignment="Center" />
    </Grid>
</Window>
